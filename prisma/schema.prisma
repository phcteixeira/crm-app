// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inbox {
  id             String    @id @default(cuid())
  name           String    @unique
  channelType    String    @default("whatsapp")
  status         String    @default("disconnected") // "connected", "disconnected", "connecting"
  credentials    Json?     // Stores qrCode, evolutionApiId, tokens safely.
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  conversations  Conversation[]
}

model Contact {
  id             String    @id @default(cuid())
  name           String?
  identifier     String    @unique // Substitui phone para poder ser email, telefone, etc.
  profilePicture String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  conversations  Conversation[]
}

model Conversation {
  id             String    @id @default(cuid())
  inboxId        String
  contactId      String
  status         String    @default("open") // "open", "resolved"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  messages       Message[]

  inbox   Inbox   @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([inboxId, contactId])
}

model Message {
  id             String   @id @default(cuid())
  text           String?
  status         String   @default("enqueued") // "enqueued", "sent", "delivered", "read", "error"
  senderType     String   // "agent" ou "contact"
  conversationId String
  mediaUrl       String?
  mediaType      String?  // 'audio', 'image', 'document', 'video'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}
